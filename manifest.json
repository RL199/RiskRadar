{
    "manifest_version": 3,
    "name": "Risk Radar",
    "version": "0.0.1",
    "description": "Analyzes website trustworthiness and risk while browsing, detecting phishing, social engineering, and manipulative content.",
    "icons": {
        "16": "assets/icons/icon-16.png",
        "32": "assets/icons/icon-32.png",
        "48": "assets/icons/icon-48.png",
        "128": "assets/icons/icon-128.png"
    },
    "permissions": ["storage", "activeTab", "scripting", "alarms", "unlimitedStorage"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "scripts/background/background.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Risk Radar",
        "default_icon": {
            "16": "assets/icons/icon-16.png",
            "32": "assets/icons/icon-32.png",
            "48": "assets/icons/icon-48.png",
            "128": "assets/icons/icon-128.png"
        }
    },
    "options_ui": {
        "page": "settings/settings.html",
        "open_in_tab": true
    }
}
